# Sao chép thành .env (local) hoặc đặt làm biến môi trường trên Coolify.

# Bí mật ký phiên Auth.js.
#  - Trên Docker/Coolify: ĐỂ TRỐNG cũng được — entrypoint tự sinh & lưu bền trên volume.
#  - Chạy local bằng `npm run dev`: nên đặt một giá trị (sinh: openssl rand -base64 32).
AUTH_SECRET=""

# Tin tưởng host khi chạy sau reverse proxy (Coolify/Traefik). Production: true
AUTH_TRUST_HOST=true

# Đường dẫn DB SQLite.
#  - Local:   file:./prisma/dev.db
#  - Coolify: file:/app/data/prod.db  (trỏ vào persistent volume — đã set sẵn trong Docker)
DATABASE_URL="file:./prisma/dev.db"

# Seed dữ liệu demo khi DB rỗng lần đầu (true/false). Đặt false nếu không muốn dữ liệu demo.
SEED_ON_FIRST_BOOT=true

# Web Push (VAPID). Trên Docker/Coolify: ĐỂ TRỐNG -> entrypoint tự sinh & lưu bền.
# Local muốn thử push: sinh bằng `npx web-push generate-vapid-keys` rồi điền 2 dòng dưới.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@goinuoc.local"
