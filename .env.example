# Sao chép thành .env (local) hoặc đặt làm biến môi trường trên Coolify.

# Bí mật ký phiên Auth.js — BẮT BUỘC. Sinh: openssl rand -base64 32
AUTH_SECRET="thay-bang-chuoi-ngau-nhien-32-byte"

# Tin tưởng host khi chạy sau reverse proxy (Coolify/Traefik). Production: true
AUTH_TRUST_HOST=true

# Đường dẫn DB SQLite.
#  - Local:   file:./prisma/dev.db
#  - Coolify: file:/app/data/prod.db  (trỏ vào persistent volume)
DATABASE_URL="file:./prisma/dev.db"

# Seed dữ liệu demo khi DB rỗng lần đầu (true/false). Production thật nên đặt false sau lần đầu.
SEED_ON_FIRST_BOOT=true
